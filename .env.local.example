# ─────────────────────────────────────────────
# WVG Admin — Environment Variables
# Copy this file to .env.local and fill values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────

# Google Sheets — server-side only, never exposed to browser
GOOGLE_SHEETS_SPREADSHEET_ID=your_google_sheet_id
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Optional: override default sheet tab names (defaults match below)
# GOOGLE_SHEET_CANDIDATES=Candidates
# GOOGLE_SHEET_EMPLOYERS=Employers
# GOOGLE_SHEET_PROJECTS=Projects
# GOOGLE_SHEET_PAYMENTS=Payments
# GOOGLE_SHEET_MONITORING=Monitoring
# GOOGLE_SHEET_DOCUMENTS=Documents

# Admin auth — generate a strong random string (32+ chars)
# openssl rand -hex 32
ADMIN_PASSWORD_HASH=
ADMIN_SESSION_SECRET=replace_with_64_char_random_hex_string

# Optional: override default admin username (default: admin)
ADMIN_USERNAME=admin
