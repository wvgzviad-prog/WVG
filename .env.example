# ─── Google Analytics 4 ───────────────────────────────────────────────────────
# Get this from: Google Analytics → Admin → Data Streams → your stream → Measurement ID
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── Microsoft Clarity ────────────────────────────────────────────────────────
# Get this from: clarity.microsoft.com → your project → Settings → Overview → Project ID
# Format: a short alphanumeric string like "abc123xyz"
NEXT_PUBLIC_CLARITY_ID=your_clarity_project_id

# ─── Google Sheets (admin backend) ───────────────────────────────────────────
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id
GOOGLE_SERVICE_ACCOUNT_EMAIL=your_service_account@project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── Admin session ────────────────────────────────────────────────────────────
SESSION_SECRET=at_least_32_characters_of_random_secret
