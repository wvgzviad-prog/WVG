  "procedure": {
    "title": "How to Go to Work in Israel?",
    "subtitle": "The employment process through Work Visa Georgia",
    "intro": "Work Visa Georgia helps candidates through every stage of the legal employment process in Israel — from initial registration to departure.",
    "duration": {
      "title": "How long does the process take?",
      "text": "In most cases, the process from registration to departure takes approximately 60 days on average. However, specific timelines may vary depending on the program, profession, and employer requirements."
